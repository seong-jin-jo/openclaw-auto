# 민감 파일 (서버에서 직접 생성)
.env
openclaw/.env

# 실제 설정 파일 (토큰 포함, 서버에서 example에서 복사)
config/openclaw.json
config/cron/jobs.json

# OpenClaw Gateway 런타임 (민감: 인증 토큰, 디바이스 키)
config/agents/
config/devices/
config/identity/

# OpenClaw Gateway 런타임 (비민감: 상태/로그)
config/memory/
config/workspace/
config/canvas/
config/logs/
config/cron/runs/
config/update-check.json
config/exec-approvals.json
config/media/
config/tasks/

# 데이터 (런타임) — .example만 추적, 실제 파일은 서비스별 로컬 관리
data/*
!data/*.example

# 로그
*.log

# Python
__pycache__/
*.pyc

# Backup files
*.bak
*.bak.*

# OS
.DS_Store

# Docker Compose (서비스별 포트/이미지 설정, .example에서 복사)
docker-compose.yml
config/credentials/
config/subagents/
config/telegram/
tenants/
